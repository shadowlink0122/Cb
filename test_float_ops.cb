// Test float operations
int main() {
    print("Test 1: "); 
    float f = 1.5f;
    println(f);
    
    print("Test 2: ");
    float g = 1.0f + 0.5f;
    println(g);
    
    print("Test 3: ");
    float h = f + 0.25f;
    println(h);
    
    print("Test 4: ");
    f = f + 0.25f;
    println(f);
    
    print("Test 5: ");
    f += 0.5f;
    println(f);
    
    return 0;
}
