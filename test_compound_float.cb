// Test compound assignment with float
int main() {
    float f = 1.5f;
    println(f);  // Should print 1.5
    
    f = f + 0.25f;  // Regular assignment with addition
    println(f);  // Should print 1.75
    
    float g = 2.0f;
    g += 0.5f;  // Compound assignment
    println(g);  // Should print 2.5
    
    return 0;
}
