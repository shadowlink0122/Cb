// シンプルな配列返り値テスト

int[3] make_int_array() {
    int[3] arr = [10, 20, 30];
    return arr;
}

int main() {
    int[3] result;
    result = make_int_array();
    println("result[0]: ");
    println(result[0]);
    println("result[1]: ");
    println(result[1]);
    println("result[2]: ");
    println(result[2]);
    return 0;
}
